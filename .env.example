# Database Configuration

# Preferred for hosted PostgreSQL providers like Neon:
DATABASE_URL=

# The hostname of your database server (e.g., localhost)
DB_HOST=localhost

# The port your database is listening on (Default for PostgreSQL is 5432)
DB_PORT=5432

# The database user
DB_USERNAME=

# The password for the database user
DB_PASSWORD=

# The name of the specific database to connect to
DB_NAME=

JWT_SECRET=

# Email configuration
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASSWORD=

# Frontend URL for reset links
FRONTEND_URL=
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-3-flash-preview

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_SAS_KEY=
AZURE_STORAGE_CONTAINER_NAME=

ENV=dev #dont put prod here https wont work i think, not sure

